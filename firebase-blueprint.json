{
  "entities": {
    "Board": {
      "title": "Board",
      "description": "A whiteboard session belonging to a user",
      "type": "object",
      "properties": {
        "ownerId": {
          "type": "string",
          "description": "User ID of the board owner"
        },
        "title": {
          "type": "string",
          "description": "Title of the board"
        },
        "data": {
          "type": "string",
          "description": "Serialized JSON string of the board's pages and elements"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownerId", "title", "data", "createdAt", "updatedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Feedback or contact message submitted by visitors",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "subject": {
          "type": "string",
          "description": "Subject of the message"
        },
        "message": {
          "type": "string",
          "description": "Content of the message"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "boards/{boardId}": {
      "schema": {
        "$ref": "#/entities/Board"
      },
      "description": "Stores user whiteboards"
    },
    "feedback/{feedbackId}": {
      "schema": {
        "$ref": "#/entities/Feedback"
      },
      "description": "Stores user feedback and contact submissions"
    }
  }
}
