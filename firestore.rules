rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /boards/{boardId} {
      allow get: if (isSignedIn() && resource != null && existing().ownerId == request.auth.uid)
        || boardId.startsWith("guest_")
        || boardId.startsWith("custom_")
        || (resource != null && (existing().ownerId.startsWith("custom_") || existing().ownerId.startsWith("guest_")));
      
      allow list: if (isSignedIn() && resource != null && existing().ownerId == request.auth.uid)
        || (resource != null && (existing().ownerId.startsWith("custom_") || existing().ownerId.startsWith("guest_")));
        
      allow create: if (isSignedIn() && isValidId(boardId) && incoming().ownerId == request.auth.uid)
        || boardId.startsWith("guest_")
        || boardId.startsWith("custom_");
        
      allow update: if (isSignedIn() && existing().ownerId == request.auth.uid)
        || existing().ownerId.startsWith("custom_")
        || existing().ownerId.startsWith("guest_");
        
      allow delete: if (isSignedIn() && existing().ownerId == request.auth.uid)
        || existing().ownerId.startsWith("custom_")
        || existing().ownerId.startsWith("guest_");
    }

    match /users/{userId} {
      allow create, get, update: if true;
    }

    match /registered_emails/{email} {
      allow create, get: if true;
    }

    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
