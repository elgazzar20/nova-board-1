rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /boards/{boardId} {
      // Allow unrestricted read/write for boards so that both Firebase-authenticated,
      // custom authenticated, and guest users can successfully manage their workspace boards.
      allow read, write: if true;
    }

    match /users/{userId} {
      allow create, get, update: if true;
    }

    match /registered_emails/{email} {
      allow create, get: if true;
    }

    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
